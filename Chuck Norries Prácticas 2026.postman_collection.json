        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "  pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Response time is less than 200ms\", function () {pm.expect(pm.response.responseTime).to.be.below(200)\r",
              "});\r",
              "pm.test(\"Content-Type incluye application/json\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "});\r",
              "pm.test(\"Categorías es una lista\", function () {\r",
              "    pm.expect(pm.response.json()).to.be.an('array');\r",
              "});\r",
              "pm.test(\"La categoría 'money' está disponible en la lista\", function () {\r",
              "    var categorias = pm.response.json();\r",
              "    pm.expect(categorias).to.include(\"money\");\r",
              "});\r",
              "pm.test(\"Contar y validar el número de categorías\", function () {\r",
              "  var categorias = pm.response.json();   \r",
              "  var totalCategorias = categorias.length;    \r",
              "pm.expect(totalCategorias).to.be.above(0);\r",
              "    console.log(\"Total de categorías encontradas: \" + totalCategorias);\r",
              "});\r",
              "pm.test(\"La API tiene exactamente 16 categorías\", function () {\r",
              "    var categorias = pm.response.json();\r",
              "pm.expect(categorias.length).to.equal(16);\r",
              "});\r",
              "\r",
              ""
